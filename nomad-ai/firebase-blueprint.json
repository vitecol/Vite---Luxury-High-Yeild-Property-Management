{
  "entities": {
    "Lead": {
      "title": "Lead",
      "description": "A lead captured from the contact form.",
      "type": "object",
      "properties": {
        "fullName": {
          "type": "string",
          "description": "Full name of the lead."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "Email address of the lead."
        },
        "phone": {
          "type": "string",
          "description": "Phone number of the lead."
        },
        "propertyLocation": {
          "type": "string",
          "description": "Location of the property."
        },
        "inquiry": {
          "type": "string",
          "description": "The detailed inquiry message."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the lead was created."
        }
      },
      "required": ["fullName", "email", "phone", "createdAt"]
    }
  },
  "firestore": {
    "leads/{leadId}": {
      "schema": "Lead",
      "description": "Collection of lead submissions."
    }
  }
}

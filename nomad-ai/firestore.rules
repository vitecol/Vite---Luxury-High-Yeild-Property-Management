rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "abduzifa@gmail.com" && request.auth.token.email_verified == true
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    // Lead validation
    function isValidLead(data) {
      return data.keys().hasAll(['fullName', 'email', 'phone', 'createdAt']) &&
             data.keys().size() <= 6 &&
             data.fullName is string && data.fullName.size() > 0 && data.fullName.size() <= 200 &&
             data.email is string && data.email.size() <= 200 && data.email.matches('^[^@]+@[^@]+\\.[^@]+$') &&
             data.phone is string && data.phone.size() <= 50 &&
             data.createdAt == request.time &&
             (!('propertyLocation' in data) || (data.propertyLocation is string && data.propertyLocation.size() <= 500)) &&
             (!('inquiry' in data) || (data.inquiry is string && data.inquiry.size() <= 5000));
    }

    match /leads/{leadId} {
      allow create: if isValidLead(incoming()) && isValidId(leadId);
      allow read, update, delete: if isAdmin();
    }
  }
}
